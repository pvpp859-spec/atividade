temperatura = float(input("qual a temperatura: "))

def calcular_temperatura(temperatura):
    Fahrenheit = (temperatura * 1.8) + 32
    return Fahrenheit

if temperatura < 15 :
    print(f"{temperatura} graus Ceslcios equivalente a {calcular_temperatura(temperatura)} graus Fahrenheit e o clima esta frio")
elif temperatura >= 15 and temperatura <= 25:
    print(f"{temperatura} graus Ceslcios equivalente a {calcular_temperatura(temperatura)} graus Fahrenheit e o clima esta agradavel")
elif temperatura > 25:
    print(f"{temperatura} graus Ceslcios equivalente a {calcular_temperatura(temperatura)} graus Fahrenheit e o clima esta quente")    